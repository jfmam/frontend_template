{
  "name": "frontend-template",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.4.4",
    "@commitlint/config-conventional": "^17.4.4",
    "@types/eslint": "^8",
    "@types/prettier": "^2",
    "eslint": "^8.36.0",
    "eslint-config-prettier": "^8.7.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.0",
    "postcss": "^8.4.23",
    "prettier": "^2.8.4",
    "stylelint": "^15.2.0",
    "stylelint-config-standard": "^30.0.1",
    "stylelint-order": "^6.0.3",
    "stylelint-prettier": "^3.0.0",
    "stylelint-scss": "^4.5.0",
    "turbo": "2.10.4",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "prepare": "husky install",
    "wesave:dev": "pnpm --filter practice-wesave dev",
    "wesave:test": "pnpm --filter practice-wesave test",
    "wesave:build": "pnpm --filter practice-wesave build",
    "wesave:deploy": "pnpm --filter practice-wesave deploy",
    "wesave:start": "pnpm --filter practice-wesave start",
    "csr-wesave:dev": "pnpm --filter csr-wesave start",
    "csr-wesave:test": "pnpm --filter csr-wesave test",
    "csr-wesave:build": "pnpm --filter csr-wesave build",
    "csr-wesave:deploy": "pnpm --filter csr-wesave deploy",
    "image-editor:dev": "pnpm --filter image-editor dev",
    "image-editor:test": "pnpm --filter image-editor test",
    "image-editor:build": "pnpm --filter image-editor build",
    "mfe:dev": "turbo run start --filter='mfe-*'",
    "mfe:build": "turbo run build --filter='mfe-*'"
  },
  "lint-staged": {
    "**/*.{tsx,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.scss": [
      "stylelint --fix"
    ]
  },
  "dependencies": {
    "postcss-scss": "^4.0.6",
    "react-router-dom": "^7.10.1"
  }
}
